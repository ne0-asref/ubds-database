{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ne0-asref/ubds-database/spec/ubds-v1.schema.json",
  "title": "UBDS — Universal Board Description Standard v1.0",
  "description": "A portable, human-readable standard for describing development boards. Every field is optional unless marked required. File extension: .ubds.yaml",
  "type": "object",
  "required": ["ubds_version", "name", "slug", "manufacturer", "board_type"],
  "additionalProperties": true,
  "properties": {
    "ubds_version": {
      "type": "string",
      "const": "1.0",
      "description": "UBDS spec version"
    },
    "name": {
      "type": "string",
      "description": "Display name of the board"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "URL-safe unique identifier"
    },
    "manufacturer": {
      "type": "string",
      "description": "Board manufacturer"
    },
    "series": {
      "type": ["string", "null"],
      "description": "Board family or product line"
    },
    "parent_board": {
      "type": ["string", "null"],
      "description": "Slug of parent board if this is a variant"
    },
    "hardware_version": {
      "type": ["string", "null"],
      "description": "Hardware revision"
    },
    "status": {
      "type": "string",
      "enum": ["active", "discontinued", "upcoming", "prototype"],
      "description": "Board availability status"
    },
    "release_date": {
      "type": ["string", "null"],
      "description": "Release date (YYYY-MM-DD)"
    },
    "end_of_life_date": {
      "type": ["string", "null"],
      "description": "End of life date (YYYY-MM-DD)"
    },
    "board_type": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "MCU", "SBC", "SoM", "Carrier", "Expansion", "FPGA",
          "AI", "SDR", "Industrial", "DSP", "Other"
        ]
      },
      "description": "Board type(s) — a board can be multiple types simultaneously"
    },
    "difficulty_level": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Target skill level"
    },
    "ecosystem_size": {
      "type": "string",
      "enum": ["small", "medium", "large", "niche"],
      "description": "Size of the board's ecosystem"
    },
    "use_cases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Intended use cases"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform tags"
    },

    "processing": {
      "type": "array",
      "items": { "$ref": "#/$defs/processing_element" },
      "description": "All processing elements on the board"
    },

    "interfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/interface" },
      "description": "Physical wired interfaces/connectors"
    },

    "pin_headers": {
      "type": "array",
      "items": { "$ref": "#/$defs/pin_header" },
      "description": "Exposed pin headers"
    },

    "wireless": {
      "type": "array",
      "items": { "$ref": "#/$defs/wireless_interface" },
      "description": "Wireless interfaces"
    },

    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/input" },
      "description": "Physical user-facing inputs"
    },

    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/output" },
      "description": "Physical user-facing outputs"
    },

    "onboard_components": {
      "$ref": "#/$defs/onboard_components",
      "description": "Addressable/controllable components on the board"
    },

    "power": {
      "$ref": "#/$defs/power_spec",
      "description": "Power specifications"
    },

    "thermal": {
      "$ref": "#/$defs/thermal_spec",
      "description": "Thermal specifications"
    },

    "physical": {
      "$ref": "#/$defs/physical_spec",
      "description": "Physical form factor and dimensions"
    },

    "boot": {
      "$ref": "#/$defs/boot_spec",
      "description": "Boot and startup configuration"
    },

    "sdr": {
      "$ref": "#/$defs/sdr_spec",
      "description": "SDR specifications (only for SDR board types)"
    },

    "certifications": {
      "type": "array",
      "items": { "$ref": "#/$defs/certification" },
      "description": "Regulatory certifications"
    },

    "software": {
      "$ref": "#/$defs/software_spec",
      "description": "Software support"
    },

    "community": {
      "$ref": "#/$defs/community_spec",
      "description": "Community and ecosystem metrics"
    },

    "resources": {
      "$ref": "#/$defs/resources_spec",
      "description": "Learning resources"
    },

    "libraries": {
      "type": "array",
      "items": { "$ref": "#/$defs/library" },
      "description": "Key software libraries"
    },

    "compatible_boards": {
      "type": "array",
      "items": { "$ref": "#/$defs/compatible_board" },
      "description": "Cross-references to compatible boards"
    },

    "metadata": {
      "$ref": "#/$defs/metadata_spec",
      "description": "Links and references"
    },

    "pricing": {
      "$ref": "#/$defs/pricing_spec",
      "description": "Pricing and availability"
    },

    "meta": {
      "$ref": "#/$defs/meta_spec",
      "description": "Provenance, confidence, verification status"
    }
  },

  "$defs": {
    "processing_element": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "part_number": { "type": ["string", "null"] },
        "role": {
          "type": "string",
          "enum": ["primary", "co-processor"]
        },
        "integrated": { "type": "boolean" },
        "type": {
          "type": "string",
          "enum": ["mcu", "fpga", "gpu", "npu", "tpu", "dsp", "hybrid"]
        },
        "hybrid_components": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["mcu", "fpga", "gpu", "npu", "tpu", "dsp"]
          }
        },
        "datasheet_url": { "type": ["string", "null"] },
        "cpu_cores": {
          "type": "array",
          "items": { "$ref": "#/$defs/cpu_core" }
        },
        "gpu": { "$ref": "#/$defs/gpu_spec" },
        "npu": { "$ref": "#/$defs/npu_spec" },
        "tpu": { "$ref": "#/$defs/tpu_spec" },
        "fpga": { "$ref": "#/$defs/fpga_spec" },
        "memory": { "$ref": "#/$defs/internal_memory" },
        "security": { "$ref": "#/$defs/security_spec" }
      }
    },

    "cpu_core": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "architecture": { "type": "string" },
        "bit_width": { "type": "integer" },
        "count": { "type": "integer", "minimum": 1 },
        "clock_mhz": { "type": "number" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "gpu_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "architecture": { "type": "string" },
        "cuda_cores": { "type": "integer" },
        "tensor_cores": { "type": "integer" },
        "clock_mhz": { "type": "number" },
        "vram_mb": { "type": ["integer", "null"] },
        "memory_bus_width_bit": { "type": "integer" },
        "tdp_w": { "type": "number" }
      }
    },

    "npu_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tops": { "type": "number" },
        "precision": {
          "type": "array",
          "items": { "type": "string" }
        },
        "power_efficiency_tops_per_w": { "type": "number" }
      }
    },

    "tpu_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tflops": { "type": "number" },
        "precision": {
          "type": "array",
          "items": { "type": "string" }
        },
        "memory_mb": { "type": "integer" }
      }
    },

    "fpga_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "family": { "type": "string" },
        "logic_cells": { "type": "integer" },
        "luts": { "type": "integer" },
        "flip_flops": { "type": "integer" },
        "embedded_memory_kb": { "type": "integer" },
        "dsp_slices": { "type": "integer" },
        "io_pins": { "type": "integer" },
        "max_clock_mhz": { "type": "number" }
      }
    },

    "internal_memory": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ram_kb": { "type": ["integer", "null"] },
        "flash_kb": { "type": ["integer", "null"] },
        "eeprom_kb": { "type": ["integer", "null"] }
      }
    },

    "security_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "secure_boot": { "type": ["boolean", "null"] },
        "secure_element": { "type": ["string", "null"] },
        "trustzone": { "type": ["boolean", "null"] },
        "hardware_crypto": { "type": ["boolean", "null"] },
        "crypto_algorithms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tamper_detection": { "type": ["boolean", "null"] },
        "secure_storage": { "type": ["boolean", "null"] }
      }
    },

    "interface": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "connector": { "type": "string" },
        "label": { "type": ["string", "null"] },
        "classification": {
          "type": "string",
          "enum": ["power", "data", "debug", "hybrid"]
        },
        "count": { "type": "integer", "minimum": 1 },
        "protocols": {
          "type": "array",
          "items": { "$ref": "#/$defs/protocol" }
        },
        "power": { "$ref": "#/$defs/interface_power" },
        "notes": { "type": ["string", "null"] }
      }
    },

    "protocol": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "speed": { "type": ["string", "null"] },
        "voltage_v": { "type": "number" },
        "lanes": { "type": "integer" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "interface_power": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "voltage_v": { "type": "number" },
        "current_a": { "type": "number" },
        "direction": {
          "type": "string",
          "enum": ["input", "output", "bidirectional"]
        },
        "supports_pd": { "type": "boolean" },
        "pd_profiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wattage_w": { "type": "number" }
      }
    },

    "pin_header": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "label": { "type": ["string", "null"] },
        "standard": { "type": "string" },
        "pin_count": { "type": "integer" },
        "pitch_mm": { "type": "number" },
        "rows": { "type": "integer" },
        "peripherals": { "$ref": "#/$defs/peripherals" },
        "voltage_levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/voltage_level" }
        },
        "power_pins": {
          "type": "array",
          "items": { "$ref": "#/$defs/power_pin" }
        },
        "pins": {
          "type": "array",
          "items": { "$ref": "#/$defs/pin" }
        }
      }
    },

    "peripherals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "gpio": { "type": ["integer", "null"] },
        "i2c": { "type": ["integer", "null"] },
        "spi": { "type": ["integer", "null"] },
        "uart": { "type": ["integer", "null"] },
        "pwm": { "type": ["integer", "null"] },
        "i2s": { "type": ["integer", "null"] },
        "adc": { "type": ["integer", "null"] },
        "dac": { "type": ["integer", "null"] },
        "can": { "type": ["integer", "null"] }
      }
    },

    "voltage_level": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "voltage_v": { "type": "number" },
        "standard": { "type": "string" }
      }
    },

    "power_pin": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pin": { "type": "integer" },
        "voltage_v": { "type": "number" },
        "max_current_ma": { "type": "number" },
        "direction": {
          "type": "string",
          "enum": ["input", "output", "bidirectional"]
        }
      }
    },

    "pin": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pin": { "type": "integer" },
        "name": { "type": "string" },
        "function": { "type": "string" },
        "protocol": { "type": "string" },
        "voltage_v": { "type": "number" },
        "alt_functions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "wireless_interface": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "protocol": { "type": "string" },
        "version": { "type": ["string", "null"] },
        "standard": { "type": ["string", "null"] },
        "frequency_bands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "module": { "type": ["string", "null"] },
        "bands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "network": { "type": ["string", "null"] },
        "antenna": { "$ref": "#/$defs/antenna" }
      }
    },

    "antenna": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["onboard", "u.fl", "sma", "ipex"]
        },
        "gain_dbi": { "type": "number" },
        "connectors": { "type": "integer" }
      }
    },

    "input": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "label": { "type": ["string", "null"] },
        "count": { "type": "integer", "minimum": 1 },
        "function": { "type": "string" }
      }
    },

    "output": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "label": { "type": ["string", "null"] },
        "color": { "type": ["string", "null"] },
        "count": { "type": "integer", "minimum": 1 },
        "function": { "type": "string" },
        "programmable": { "type": "boolean" },
        "technology": { "type": "string" },
        "resolution": { "type": "string" },
        "interface": { "type": "string" },
        "size_inches": { "type": "number" },
        "touchscreen": { "type": "boolean" }
      }
    },

    "onboard_components": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sensors": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "actuators": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "display_controllers": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "memory": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "power_management": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "audio": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "networking": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "crypto": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "other": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        }
      }
    },

    "component": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "part_number": { "type": ["string", "null"] },
        "manufacturer": { "type": ["string", "null"] },
        "interface": { "type": "string" },
        "datasheet_url": { "type": ["string", "null"] }
      }
    },

    "power_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "input_voltage_min_v": { "type": "number" },
        "input_voltage_max_v": { "type": "number" },
        "recommended_voltage_v": { "type": "number" },
        "recommended_wattage_w": { "type": "number" },
        "operating_voltage_v": { "type": "number" },
        "provides": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "voltage_v": { "type": "number" },
              "max_current_ma": { "type": "number" }
            }
          }
        },
        "battery": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "connector": { "type": ["string", "null"] },
            "chemistry": {
              "type": "array",
              "items": { "type": "string" }
            },
            "charging_circuit": { "type": "boolean" },
            "solar_input": { "type": "boolean" }
          }
        },
        "consumption": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "mode": { "type": "string" },
              "current_ma": { "type": "number" },
              "current_ua": { "type": "number" },
              "notes": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "thermal_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tdp_w": { "type": "number" },
        "operating_temp_min_c": { "type": "number" },
        "operating_temp_max_c": { "type": "number" },
        "storage_temp_min_c": { "type": "number" },
        "storage_temp_max_c": { "type": "number" },
        "heatsink": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "included": { "type": "boolean" },
            "type": {
              "type": "string",
              "enum": ["active", "passive", "none"]
            }
          }
        },
        "thermal_throttle_temp_c": { "type": "number" },
        "notes": { "type": ["string", "null"] }
      }
    },

    "physical_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dimensions_mm": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "length": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" }
          }
        },
        "weight_g": { "type": "number" },
        "form_factor": {
          "type": "array",
          "items": { "type": "string" }
        },
        "breadboard_friendly": { "type": "boolean" },
        "mounting_holes": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "count": { "type": "integer" },
            "pattern": { "type": "string" },
            "diameter_mm": { "type": "number" }
          }
        },
        "enclosure_available": { "type": "boolean" }
      }
    },

    "boot_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "boot_media": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default_boot": { "type": ["string", "null"] },
        "bootloader": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boot_time_seconds": { "type": ["number", "null"] }
      }
    },

    "sdr_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "frequency_range_mhz": {
          "type": "object",
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "bandwidth_mhz": { "type": "number" },
        "sample_rate_msps": { "type": "number" },
        "adc_resolution_bits": { "type": "integer" },
        "dac_resolution_bits": { "type": "integer" },
        "rx_channels": { "type": "integer" },
        "tx_channels": { "type": "integer" },
        "duplex": {
          "type": "string",
          "enum": ["full", "half", "simplex"]
        },
        "supported_frameworks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "certification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "id": { "type": ["string", "null"] },
        "region": { "type": ["string", "null"] },
        "test_report_url": { "type": ["string", "null"] }
      }
    },

    "software_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "languages": {
          "type": "array",
          "items": { "$ref": "#/$defs/software_entry" }
        },
        "frameworks": {
          "type": "array",
          "items": { "$ref": "#/$defs/software_entry" }
        },
        "os": {
          "type": "array",
          "items": { "$ref": "#/$defs/software_entry" }
        },
        "ai_ml_tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/software_entry" }
        },
        "ides": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" }
            }
          }
        },
        "debugger_support": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" },
              "interface": { "type": "string" }
            }
          }
        }
      }
    },

    "software_entry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "support_level": {
          "type": "string",
          "enum": ["board", "controller", "community", "experimental", "not_supported"]
        },
        "version": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "variant": { "type": ["string", "null"] },
        "board_manager_url": { "type": ["string", "null"] },
        "platform_id": { "type": ["string", "null"] },
        "board_id": { "type": ["string", "null"] }
      }
    },

    "community_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "github_repos": { "type": ["integer", "null"] },
        "forum_url": { "type": ["string", "null"] },
        "stackoverflow_tag": { "type": ["string", "null"] },
        "stackoverflow_questions": { "type": ["integer", "null"] },
        "discord_url": { "type": ["string", "null"] },
        "subreddit": { "type": ["string", "null"] },
        "avg_rating": { "type": ["number", "null"] },
        "review_count": { "type": ["integer", "null"] }
      }
    },

    "resources_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "board": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource" }
        },
        "controller": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource" }
        },
        "core": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource" }
        }
      }
    },

    "resource": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "format": {
          "type": "string",
          "enum": [
            "tutorial", "video", "course", "book", "blog",
            "documentation", "wiki", "example_code", "webinar", "other"
          ]
        },
        "cost": {
          "type": "string",
          "enum": ["free", "paid", "freemium"]
        },
        "language": { "type": ["string", "null"] },
        "framework": { "type": ["string", "null"] },
        "author": { "type": ["string", "null"] },
        "platform": { "type": ["string", "null"] }
      }
    },

    "library": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "language": { "type": "string" },
        "framework": { "type": ["string", "null"] },
        "category": { "type": ["string", "null"] },
        "repo_url": { "type": ["string", "null"] },
        "package_url": { "type": ["string", "null"] }
      }
    },

    "compatible_board": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "slug": { "type": "string" },
        "relationship": {
          "type": "string",
          "enum": [
            "module", "carrier", "shield", "hat",
            "cape", "click_board", "expansion", "other"
          ]
        },
        "notes": { "type": ["string", "null"] }
      }
    },

    "metadata_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "official_page_url": { "type": ["string", "null"] },
        "image_url": { "type": ["string", "null"] },
        "image_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["top-view", "angle", "sim-ready", "pinout", "block-diagram"]
          }
        },
        "pinout_image_url": { "type": ["string", "null"] },
        "pinout_table_url": { "type": ["string", "null"] },
        "schematic_url": { "type": ["string", "null"] },
        "repo_url": { "type": ["string", "null"] },
        "datasheet_url": { "type": ["string", "null"] },
        "getting_started_urls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_hardware_repo_url": { "type": ["string", "null"] },
        "processing_element_datasheets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },

    "pricing_spec": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "msrp_usd": { "type": ["number", "null"] },
        "vendors": {
          "type": "array",
          "items": { "$ref": "#/$defs/vendor" }
        }
      }
    },

    "vendor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "price_usd": { "type": ["number", "null"] },
        "in_stock": { "type": "boolean" },
        "affiliate_url": { "type": ["string", "null"] }
      }
    },

    "meta_spec": {
      "type": "object",
      "required": ["sources"],
      "additionalProperties": true,
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "At least one verifiable public URL"
        },
        "last_verified": { "type": ["string", "null"] },
        "data_completeness": {
          "type": "string",
          "enum": ["full", "partial", "stub"]
        },
        "community_reviewed": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "processing": { "$ref": "#/$defs/confidence_level" },
            "interfaces": { "$ref": "#/$defs/confidence_level" },
            "wireless": { "$ref": "#/$defs/confidence_level" },
            "software": { "$ref": "#/$defs/confidence_level" },
            "power": { "$ref": "#/$defs/confidence_level" },
            "pricing": { "$ref": "#/$defs/confidence_level" }
          }
        }
      }
    },

    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  }
}
